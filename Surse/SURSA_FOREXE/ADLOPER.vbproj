			<DependentUpon>WorkflowEditorForm.vb</DependentUpon>
		</Compile>
		<Compile Update="Helpers\WorkflowEditorForm.Help.vb">
			<SubType>Code</SubType>
			<DependentUpon>WorkflowEditorForm.vb</DependentUpon>
		</Compile>
	</ItemGroup>

	<ItemGroup>
		<Compile Update="KBOT_IPC.Variables.vb">
			<SubType>Code</SubType>
			<DependentUpon>KBOT_IPC.vb</DependentUpon>
		</Compile>
		<Compile Update="KBOT_IPC.Monitoring.vb">
			<SubType>Code</SubType>
			<DependentUpon>KBOT_IPC.vb</DependentUpon>
		</Compile>
		<Compile Update="KBOT_IPC.Pipe.vb">
			<SubType>Code</SubType>
			<DependentUpon>KBOT_IPC.vb</DependentUpon>
		</Compile>
		<Compile Update="KBOT_IPC.Window.vb">
			<SubType>Code</SubType>
			<DependentUpon>KBOT_IPC.vb</DependentUpon>
		</Compile>
		<Compile Update="KBOT_IPC.WorkFlow.vb">
			<SubType>Code</SubType>
			<DependentUpon>KBOT_IPC.vb</DependentUpon>
		</Compile>
		<Compile Update="KBOT_IPC.Resend.vb">
			<SubType>Code</SubType>
			<DependentUpon>KBOT_IPC.vb</DependentUpon>
		</Compile>
		<Compile Update="KBOT_IPC.ForexeSNM.vb">
			<SubType>Code</SubType>
			<DependentUpon>KBOT_IPC.vb</DependentUpon>
		</Compile>
